generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth.js Models ──────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Sede ─────────────────────────────────────────────────────

model Sede {
  id          Int      @id @default(autoincrement())
  nombre      String   @unique
  codigo      String   @unique
  direccion   String?
  telefono    String?
  activa      Boolean  @default(true)
  mallaCurriculares  MallaCurricular[]
  estudiantes        Estudiante[]
  docenteAsignaturas DocenteAsignatura[]
  periodosExamen     PeriodoExamen[]
  horariosClase      HorarioClase[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Domain Models ───────────────────────────────────────────

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  emailVerified DateTime?
  image         String?
  password      String?
  rol           String          @default("ESTUDIANTE")
  activo        Boolean         @default(true)
  telefono      String?
  prefNotificaciones String?
  accounts      Account[]
  sessions      Session[]
  docente       Docente?
  estudiante    Estudiante?
  notificaciones Notificacion[]
  sesionesLogin  SesionLogin[]
  actividades    ActividadUsuario[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model SesionLogin {
  id          Int      @id @default(autoincrement())
  usuarioId   String
  ip          String?
  navegador   String?
  dispositivo String?
  exitoso     Boolean  @default(true)
  usuario     User     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model ActividadUsuario {
  id         Int      @id @default(autoincrement())
  usuarioId  String
  accion     String
  entidad    String
  entidadId  String?
  detalle    String?
  ip         String?
  usuario    User     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model Notificacion {
  id          Int      @id @default(autoincrement())
  usuarioId   String
  tipo        String
  titulo      String
  mensaje     String
  enlace      String?
  leida       Boolean  @default(false)
  usuario     User     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model MallaCurricular {
  id              Int           @id @default(autoincrement())
  nombre          String
  codigo          String        @unique
  descripcion     String?
  totalSemestres  Int
  activa          Boolean       @default(true)
  sedeId          Int?
  sede            Sede?         @relation(fields: [sedeId], references: [id])
  asignaturas     Asignatura[]
  estudiantes     Estudiante[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Asignatura {
  id                Int                     @id @default(autoincrement())
  nombre            String
  codigo            String                  @unique
  semestre          Int
  creditos          Int                     @default(0)
  horasTeoricas     Int                     @default(0)
  horasPracticas    Int                     @default(0)
  mallaCurricularId Int
  mallaCurricular   MallaCurricular         @relation(fields: [mallaCurricularId], references: [id], onDelete: Cascade)
  prerequisitos     AsignaturaPrerequisito[] @relation("asignatura")
  esPrerequisitoDe  AsignaturaPrerequisito[] @relation("prerequisito")
  docenteAsignaturas DocenteAsignatura[]
  inscripciones     Inscripcion[]
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
}

model AsignaturaPrerequisito {
  id              Int        @id @default(autoincrement())
  asignaturaId    Int
  prerequisitoId  Int
  asignatura      Asignatura @relation("asignatura", fields: [asignaturaId], references: [id], onDelete: Cascade)
  prerequisito    Asignatura @relation("prerequisito", fields: [prerequisitoId], references: [id], onDelete: Cascade)

  @@unique([asignaturaId, prerequisitoId])
}

model Docente {
  id                  Int                  @id @default(autoincrement())
  usuarioId           String               @unique
  especialidad        String?
  titulo              String?
  telefono            String?
  usuario             User                 @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  docenteAsignaturas  DocenteAsignatura[]
  inscripciones       Inscripcion[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model DocenteAsignatura {
  id           Int        @id @default(autoincrement())
  docenteId    Int
  asignaturaId Int
  sedeId       Int?
  gestion      Int
  periodo      String
  docente      Docente    @relation(fields: [docenteId], references: [id], onDelete: Cascade)
  asignatura   Asignatura @relation(fields: [asignaturaId], references: [id], onDelete: Cascade)
  sede         Sede?      @relation(fields: [sedeId], references: [id])
  contenidosClase     ContenidoClase[]
  evaluaciones        RegistroEvaluacion[]
  horariosClase       HorarioClase[]

  @@unique([docenteId, asignaturaId, gestion, periodo])
}

model Estudiante {
  id                Int              @id @default(autoincrement())
  usuarioId         String           @unique
  matricula         String           @unique
  mallaCurricularId Int
  sedeId            Int?
  semestreActual    Int              @default(1)
  usuario           User             @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  mallaCurricular   MallaCurricular  @relation(fields: [mallaCurricularId], references: [id])
  sede              Sede?            @relation(fields: [sedeId], references: [id])
  inscripciones     Inscripcion[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model Inscripcion {
  id            Int            @id @default(autoincrement())
  estudianteId  Int
  asignaturaId  Int
  docenteId     Int
  semestre      Int
  gestion       Int
  periodo       String
  estado        String         @default("CURSANDO")
  estudiante    Estudiante     @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
  asignatura    Asignatura     @relation(fields: [asignaturaId], references: [id])
  docente       Docente        @relation(fields: [docenteId], references: [id])
  calificaciones Calificacion[]
  asistencias   Asistencia[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([estudianteId, asignaturaId, gestion, periodo])
}

model Calificacion {
  id              Int         @id @default(autoincrement())
  inscripcionId   Int
  trabajoPractico Float?
  examenParcial   Float?
  examenFinal     Float?
  notaFinal       Float?
  tipoExamen      String      @default("NORMAL")
  observacion     String?
  inscripcion     Inscripcion @relation(fields: [inscripcionId], references: [id], onDelete: Cascade)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([inscripcionId, tipoExamen])
}

model Asistencia {
  id            Int         @id @default(autoincrement())
  inscripcionId Int
  fecha         DateTime
  presente      Boolean     @default(false)
  observacion   String?
  inscripcion   Inscripcion @relation(fields: [inscripcionId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([inscripcionId, fecha])
}

model PeriodoExamen {
  id          Int      @id @default(autoincrement())
  tipo        String
  sedeId      Int?
  gestion     Int
  periodo     String
  fechaInicio DateTime
  fechaFin    DateTime
  habilitado  Boolean  @default(false)
  sede        Sede?    @relation(fields: [sedeId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tipo, gestion, periodo, sedeId])
}

model ArchivoExamen {
  id            Int      @id @default(autoincrement())
  nombre        String
  rutaArchivo   String
  tipoExamen    String
  asignaturaId  Int
  docenteId     Int
  gestion       Int
  periodo       String
  createdAt     DateTime @default(now())
}

// ─── Plan de Clase y Evaluación Docente ──────────────────────

model ContenidoClase {
  id                  Int      @id @default(autoincrement())
  docenteAsignaturaId Int
  tipoClase           String
  fecha               DateTime
  modalidad           String
  contenido           String
  metodologias        String
  observaciones       String?
  docenteAsignatura   DocenteAsignatura @relation(fields: [docenteAsignaturaId], references: [id], onDelete: Cascade)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model RegistroEvaluacion {
  id                  Int      @id @default(autoincrement())
  docenteAsignaturaId Int
  fecha               DateTime
  puntosAsignados     Float
  instrumentos        String
  descripcion         String?
  docenteAsignatura   DocenteAsignatura @relation(fields: [docenteAsignaturaId], references: [id], onDelete: Cascade)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ─── Horario de Clases por Sede ──────────────────────────────

model HorarioClase {
  id                  Int               @id @default(autoincrement())
  sedeId              Int
  docenteAsignaturaId Int
  diaSemana           Int
  horaInicio          String
  horaFin             String
  aula                String?
  fechaInicio         String?
  fechaFin            String?
  sede                Sede              @relation(fields: [sedeId], references: [id], onDelete: Cascade)
  docenteAsignatura   DocenteAsignatura @relation(fields: [docenteAsignaturaId], references: [id], onDelete: Cascade)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@unique([sedeId, docenteAsignaturaId, diaSemana, horaInicio])
}
